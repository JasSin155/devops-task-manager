{
  "name": "devops-task-manager",
  "version": "1.0.0",
  "description": "Task Manager REST API used to demonstrate a full Jenkins CI/CD pipeline (SIT223/SIT753 HD task).",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --testPathPattern=tests/unit --reporters=default --reporters=jest-junit",
    "test:integration": "jest --testPathPattern=tests/integration --reporters=default --reporters=jest-junit",
    "test:all": "jest --coverage --reporters=default --reporters=jest-junit",
    "lint": "eslint src tests --ext .js",
    "audit:check": "npm audit --audit-level=high --json > npm-audit.json || true"
  },
  "keywords": ["devops", "jenkins", "ci-cd", "express", "rest-api"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "prom-client": "^15.1.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest-junit": {
    "outputDirectory": "test-results",
    "outputName": "junit.xml"
  }
}
